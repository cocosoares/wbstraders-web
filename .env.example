# Sitio
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_LEGAL_NAME=
NEXT_PUBLIC_RUC=
NEXT_PUBLIC_LEGAL_ADDRESS=
NEXT_PUBLIC_SUPPORT_EMAIL=ventas@wbstraders.com

# Supabase (usar proyecto separado para desarrollo y producción)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_EMAILS=

# Email transaccional y marketing / Resend (solo servidor, salvo SUPPORT_EMAIL)
RESEND_API_KEY=
# Clave Full access separada; se usa solo para altas/bajas de contactos.
RESEND_CONTACTS_API_KEY=
RESEND_WEBHOOK_SECRET=
RESEND_FROM="WBStraders <pedidos@mail.tudominio.com>"
RESEND_REPLY_TO=greciasemorile@gmail.com
EMAIL_OPERATIONS_TO=greciasemorile@gmail.com
# En pruebas redirige TODOS los correos transaccionales a esta única bandeja.
EMAIL_TEST_RECIPIENT=
# Mantener ambos en false hasta verificar dominio, webhook, cola y correos de prueba.
EMAIL_TRANSACTIONAL_ENABLED=false
EMAIL_MARKETING_SYNC_ENABLED=false

# CRM de WhatsApp (la interfaz nueva se publica detrás de este flag)
CRM_DASHBOARD_V2=false
CRM_SLA_MINUTES=10
CRM_ALERTS_24_7=true
CRM_ALERT_EMAILS=greciasemorile@gmail.com

# Pagos: `manual` permite probar pedidos sin marcar pagos como aprobados
PAYMENT_PROVIDER=manual
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# WhatsApp / YCloud
YCLOUD_API_KEY=
YCLOUD_WEBHOOK_SECRET=
YCLOUD_WHATSAPP_NUMBER=
YCLOUD_PAYMENT_CONFIRMED_TEMPLATE=
YCLOUD_TEMPLATE_LANGUAGE=es_PE
WHATSAPP_PROVIDER=ycloud
GREEN_API_URL=
GREEN_API_INSTANCE_ID=
GREEN_API_TOKEN=
GREEN_API_WEBHOOK_SECRET=
# Habilitar solo después de verificar el webhook, la mayoría de edad y las
# plantillas de Meta/YCloud. Los mensajes libres se envían únicamente dentro de
# la ventana activa iniciada por el cliente.
WHATSAPP_BOT_ENABLED=false
WHATSAPP_OUTBOUND_ENABLED=false
WHATSAPP_WEBHOOK_TOLERANCE_SECONDS=300

# Protege endpoints internos de cron; generar un valor aleatorio largo por entorno
CRON_SECRET=

# Analítica (no enviar PII)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_ID=

# Sommelier
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
