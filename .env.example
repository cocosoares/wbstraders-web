# URL pública del sitio (usada en SEO, sitemap y OpenGraph)
NEXT_PUBLIC_SITE_URL=https://www.wbstraders.com

# Clave de API de OpenRouter para el Sommelier IA (https://openrouter.ai/keys)
# Si se deja vacía, el sommelier funciona en modo reglas (recomendador local).
OPENROUTER_API_KEY=

# Modelo a usar para el Sommelier (opcional, ver https://openrouter.ai/models)
SOMMELIER_MODEL=google/gemini-3.1-flash-lite
